# === Authentification codeur.com ===
# Ouvrir DevTools > Application > Cookies > codeur.com
# Copier les cookies de session ici (format: nom=valeur; nom2=valeur2)
# Ou via l'extension EditThisCookies
CODEUR_COOKIES=_pk_id.1.69e9=abc123def456.1767652089.; _pk_ref.1.69e9=%5B%22%22%2C%22%22%2C1771924497%5D; _pk_ses.1.69e9=1; accept_codeur_cookies=true; ahoy_visit=00000000-0000-0000-0000-000000000000; ahoy_visitor=00000000-0000-0000-0000-000000000000; chat=false; offer_user_token=VOTRE_TOKEN_ICI

# === OpenAI ===
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# === Scraping ===
SCRAPE_PAGES=3
# Nombre de fois que le bot clique sur "Voir plus" pour charger les annonces
SCRAPE_INTERVAL_MINUTES=15
BASE_URL=https://www.codeur.com
# URL de scraping (page des projets dev)
SCRAPE_URL=https://www.codeur.com/developpeur

# === Filtre ===
# Mots-cles separes par des virgules (insensible a la casse)
FILTER_KEYWORDS=next,nextjs,next.js,nest,nestjs,nest.js,react,node,nodejs,node.js,mongodb,mongo,typescript,javascript,api,fullstack,full-stack

# === Proposition par defaut ===
DEFAULT_DAILY_RATE=450
DEFAULT_DELIVERY_DAYS=14

# === Identité freelance ===
FREELANCER_NAME=Prénom
PORTFOLIO_URL=https://votresite.fr/
CONTACT_EMAIL=votre@email.com

# === Comportement ===
# true = le bot ne soumet PAS les propositions (mode test)
DRY_RUN=true
HEADLESS=true
LOG_LEVEL=info
